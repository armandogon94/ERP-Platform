# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-random-string-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Ports
DJANGO_PORT=14000
REACT_PORT=14500
POSTGRES_PORT=5432
REDIS_PORT=6379

# PostgreSQL
POSTGRES_DB=erp_dev
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_pass
DATABASE_URL=postgres://erp_user:erp_pass@postgres:5432/erp_dev

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# Frontend
VITE_API_URL=http://localhost:14000
